        "jsCode": "const items = $json.data;\n\nlet text = \"🏛️ 📰 ۸ پربیننده ترین اخبار سیاسی\\n\\n\";\n\nfor (let i = 0; i < Math.min(8, items.length); i++) {\n\n    const html = items[i];\n\n    // عنوان\n    const titleMatch = html.match(/>([^<]+)<\\/a>/);\n    const title = titleMatch ? titleMatch[1].trim() : \"بدون عنوان\";\n\n    // لینک\n    const hrefMatch = html.match(/href=\"([^\"]+)\"/);\n    const href = hrefMatch ? hrefMatch[1] : \"\";\n\n    // زمان\n    const timeMatch = html.match(/<span[^>]*class=\"[^\"]*minw80[^\"]*\"[^>]*>(.*?)<\\/span>/);\n    const time = timeMatch ? timeMatch[1].trim() : \"\";\n\n    text += `${i + 1}️⃣ ${title}\\n`;\n    text += `🕒 ${time}\\n`;\n    text += `🔗 ${href}\\n\\n`;\n}\n\nreturn [{\n    json: {\n        chat_id: $(\"Merge\").first().json.chat_id,\n        text\n    }\n}];"
      },
