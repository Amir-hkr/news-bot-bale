    {
      "parameters": {
        "jsCode": "const items = $json.data;\n\nlet text = \"🤖 8 خبر جدید هوش مصنوعی\\n\\n\";\n\nfor (let i = 0; i < Math.min(8, items.length); i++) {\n\n    const html = items[i];\n\n    // لینک عنوان\n    const hrefMatch = html.match(/<h2[^>]*class=\"elementor-post__title\"[\\s\\S]*?<a[^>]*href=\"([^\"]+)\"/);\n    const href = hrefMatch ? hrefMatch[1] : \"\";\n\n    // عنوان\n    const titleMatch = html.match(/<h2[^>]*class=\"elementor-post__title\"[\\s\\S]*?<a[^>]*>([\\s\\S]*?)<\\/a>/);\n    const title = titleMatch\n        ? titleMatch[1].replace(/\\s+/g, \" \").trim()\n        : \"بدون عنوان\";\n\n    // تاریخ\n    const dateMatch = html.match(/<span[^>]*class=\"elementor-post-date\"[^>]*>([\\s\\S]*?)<\\/span>/);\n    const date = dateMatch\n        ? dateMatch[1].replace(/\\s+/g, \" \").trim()\n        : \"\";\n\n    text += `${i + 1}️⃣ ${title}\\n`;\n    text += `📅 ${date}\\n`;\n    text += `🔗 ${href}\\n\\n`;\n}\n\nreturn [{\n    json: {\n        chat_id: $(\"Merge\").first().json.chat_id,\n        text\n    }\n}];"
      },
